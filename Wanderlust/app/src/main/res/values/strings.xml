    <string name="legal_section_overview">Overview</string>
    <string name="legal_privacy_overview">Wanderlust is a student project that helps you discover temples, coast, mountains, and food across Cambodia. This policy explains what we collect and why.</string>
    <string name="legal_section_data_collect">What we collect</string>
    <string name="legal_privacy_data_collect">Account name and email (to sign in), saved places (synced when logged in), and optional profile bio. We do not collect payment details — the app has no checkout.</string>
    <string name="legal_section_data_use">How we use it</string>
    <string name="legal_privacy_data_use">Your data powers login, profile display, and syncing favorites between your phone and our server. Location is used only when you open maps or nearby suggestions — not tracked in the background.</string>
    <string name="legal_section_storage">Storage &amp; sharing</string>
    <string name="legal_privacy_storage">Data is stored on our PostgreSQL server for this course project. We do not sell your information to third parties. Use a test email for classroom demos when possible.</string>
    <string name="legal_section_rights">Your choices</string>
    <string name="legal_privacy_rights">You can update your name and bio in Profile → Edit profile. Email changes require support. To remove your account or data, contact your instructor or project support.</string>
    <string name="legal_terms_overview">By using Wanderlust you agree to these terms. Please read them before signing in or saving places.</string>
    <string name="legal_section_terms_service">The service</string>
    <string name="legal_terms_service">Wanderlust provides travel inspiration and saved-place lists only. It is not a booking, ticketing, or payment platform. Place details may change; always verify before you travel.</string>
    <string name="legal_section_terms_account">Your account</string>
    <string name="legal_terms_account">Sign in for full access to all destinations and saved lists. Keep your password private. You are responsible for activity on your account. Guest mode shows a limited preview only.</string>
    <string name="legal_section_terms_use">Acceptable use</string>
    <string name="legal_terms_use">Do not abuse the API, attempt to access admin tools without permission, scrape data, or upload harmful content. Admin features are restricted to authorized admin accounts.</string>
    <string name="legal_section_terms_changes">Changes</string>
    <string name="legal_terms_changes">We may update destinations, features, or these policies for the course project without prior notice. Continued use of the app means you accept the current terms.</string>
    <string name="legal_footer_note">Questions? Contact your ITE304k instructor or project team.</string>
